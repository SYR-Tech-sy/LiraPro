# ============================================================
# LiraPro — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Supabase (required) ---
# Found at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Database (required) ---
# Found at: https://supabase.com/dashboard/project/_/settings/database
# Use the "URI" connection string (Transaction mode, port 6543)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-xx-xx-x.pooler.supabase.com:6543/postgres

# --- Session (required) ---
# Any random string, at least 32 characters
SESSION_SECRET=change_this_to_a_random_32_char_string_minimum

# --- Admin (optional) ---
# Token required to access admin panel endpoints
ADMIN_TOKEN=SYRSYP2026ADMIN

# --- Metal Prices (optional) ---
# Get a free key at: https://metalpriceapi.com
METAL_PRICE_API_KEY=
